* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: Arial, sans-serif;
    background: linear-gradient(120deg, #1e3c72, #2a5298);
    color: white;
}

/* NAVBAR */
nav {
    display: flex;
    justify-content: space-between;
    padding: 20px;
    background: rgba(0,0,0,0.6);
}

nav ul {
    display: flex;
    gap: 20px;
    list-style: none;
}

nav a {
    color: white;
    text-decoration: none;
}

/* SECTIONS */
.section {
    padding: 80px 20px;
    text-align: center;
}

/* HOME */
.home span {
    color: #ff9800;
}

/* BUTTON */
button {
    padding: 10px 20px;
    border: none;
    background: #ff9800;
    color: white;
    border-radius: 5px;
    cursor: pointer;
}

button:hover {
    transform: scale(1.1);
    transition: 0.3s;
}

/* PROJECT CARDS */
.project-card {
    background: rgba(255,255,255,0.1);
    margin: 20px;
    padding: 20px;
    border-radius: 10px;
    backdrop-filter: blur(10px);
}

/* FORM */
input, textarea {
    display: block;
    margin: 10px auto;
    padding: 10px;
    width: 80%;
    border-radius: 5px;
    border: none;
}

/* FOOTER */
footer {
    padding: 20px;
    background: black;
}
